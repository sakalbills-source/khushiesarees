# ----------------------------------------------------------------------------
# KSarees environment variables
# Copy this file to `.env.local` and fill in your values.
# The app ships with mock/seed data and works WITHOUT these set, but you will
# need them for a live database and real payments.
# ----------------------------------------------------------------------------

# Supabase (https://app.supabase.com -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key is server-only (used by admin + checkout). NEVER expose it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (https://dashboard.stripe.com/test/apikeys). Test keys are fine.
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Admin panel password (used by /admin/products auth guard)
ADMIN_PASSWORD=changeme

# Public base URL (used for Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
