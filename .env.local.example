# ----------------------------------------------------------------------------
# KSarees environment variables
# Copy this file to `.env.local` and fill in your values.
#
# The catalogue is EMPTY by default (no mock/seed data). Without Supabase the
# store renders a clean "Coming soon" state. Add Supabase to load real products
# and Stripe to take live card payments.
#
# Currency: AUD is the canonical base. Live FX rates come from a keyless public
# API (open.er-api.com), so NO FX API key is required.
# ----------------------------------------------------------------------------

# Supabase (https://app.supabase.com -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key is server-only (used by admin + checkout). NEVER expose it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (https://dashboard.stripe.com/test/apikeys). Test keys are fine.
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Admin panel password (used by /admin/products auth guard)
ADMIN_PASSWORD=changeme

# Public base URL (used for Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
